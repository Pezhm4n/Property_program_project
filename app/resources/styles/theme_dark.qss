/* theme_dark.qss - Premium Dark Colors */
QMainWindow, QDialog, QFrame, QStackedWidget {
    background-color: #0f172a;
    color: #f8fafc;
}

QLabel, QCheckBox, QRadioButton {
    background-color: transparent;
    color: #f8fafc;
}

QWidget#loginCard {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 16px;
}

QLabel#loginTitle {
    color: #f8fafc;
    font-size: 22px;
    font-weight: bold;
}

QLabel#dashboardTitle {
    color: #f8fafc;
    font-size: 20px;
    font-weight: bold;
}

QWidget#sidebarContainer {
    background-color: #0f172a;
    border-right: 1px solid #334155;
}
QListWidget#sidebarWidget {
    background-color: #0f172a;
}

QFrame#StatisticsCard {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
}
QFrame#StatisticsCard:hover {
    border-color: #475569;
    background-color: #334155;
}
QLabel#statTitle {
    color: #94a3b8;
    font-size: 13px;
    font-weight: bold;
}
QLabel#statValue {
    color: #f8fafc;
    font-size: 26px;
    font-weight: bold;
}
QLabel#statDesc {
    color: #64748b;
    font-size: 11px;
}

QFrame#ChartWidget {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
}
QLabel#chartTitle {
    color: #f8fafc;
    font-size: 14px;
    font-weight: bold;
}

QFrame#RecentActivityWidget {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
}
QLabel#activityTitle {
    color: #f8fafc;
    font-size: 14px;
    font-weight: bold;
}
QListWidget#activityList {
    background: transparent;
    border: none;
    color: #cbd5e1;
}
QListWidget#activityList::item {
    border-bottom: 1px solid #334155;
    padding: 8px;
}
QListWidget#activityList::item:hover {
    background-color: #334155;
    border-radius: 6px;
    color: #f8fafc;
}

QLineEdit, QSpinBox, QComboBox {
    background-color: #1e293b;
    color: #f8fafc;
    border: 1px solid #334155;
}

QLineEdit:focus, QSpinBox:focus, QComboBox:focus {
    border: 1.5px solid #0ea5e9;
}

QListWidget {
    background-color: #0f172a;
}
QListWidget::item {
    color: #94a3b8;
}
QListWidget::item:hover {
    background-color: #1e293b;
    color: #f8fafc;
}
QListWidget::item:selected {
    background-color: #0ea5e9;
    color: #ffffff;
}

QPushButton {
    background-color: #0284c7;
    color: white;
    border: none;
}
QPushButton:hover {
    background-color: #0ea5e9;
}
QPushButton:pressed {
    background-color: #0369a1;
}
QPushButton:disabled {
    background-color: #334155;
    color: #94a3b8;
}

QTableView {
    background-color: #1e293b;
    gridline-color: #334155;
    border: 1px solid #334155;
    color: #f8fafc;
    selection-background-color: rgba(14, 165, 233, 0.2);
    selection-color: #f8fafc;
}
QHeaderView::section {
    background-color: #0f172a;
    color: #94a3b8;
    border-bottom: 2px solid #334155;
}
QTableView::item {
    border-bottom: 1px solid #334155;
}
QTableView::item:hover {
    background-color: rgba(99, 102, 241, 0.1);
}

QToolBar {
    background-color: #1e293b;
    border-bottom: 1px solid #334155;
}
QToolBar QToolButton {
    color: #f8fafc;
}
QToolBar QToolButton:hover {
    background-color: #334155;
}
QToolBar QToolButton:pressed {
    background-color: #475569;
}

QStatusBar {
    background-color: #0f172a;
    color: #64748b;
    border-top: 1px solid #334155;
}

QMenu {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 8px;
    padding: 4px;
}
QMenu::item {
    padding: 6px 20px;
    border-radius: 4px;
    color: #f8fafc;
}
QMenu::item:selected {
    background-color: #0ea5e9;
    color: #ffffff;
}

QLabel#reportsHeader {
    color: #f8fafc;
    font-size: 22px;
    font-weight: bold;
}
QLabel#reportsDesc {
    color: #94a3b8;
    font-size: 13px;
}
QFrame#reportsPdfCard, QFrame#reportsExcelCard {
    background-color: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
}
QFrame#reportsPdfCard:hover, QFrame#reportsExcelCard:hover {
    border-color: #475569;
}
QLabel#reportsPdfTitle {
    color: #38bdf8;
    font-size: 16px;
    font-weight: bold;
}
QLabel#reportsExcelTitle {
    color: #34d399;
    font-size: 16px;
    font-weight: bold;
}
QLabel#reportsPdfDesc, QLabel#reportsExcelDesc {
    color: #cbd5e1;
    font-size: 12px;
}
QPushButton#reportsBtnPdf {
    background-color: #0284c7;
}
QPushButton#reportsBtnExcel {
    background-color: #059669;
}
