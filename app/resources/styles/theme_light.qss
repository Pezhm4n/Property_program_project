/* theme_light.qss */
QMainWindow, QWidget {
    background-color: #ffffff;
    color: #000000;
}

QLineEdit {
    background-color: #f0f0f0;
    color: #000000;
    border: 1px solid #ccc;
}

QPushButton {
    background-color: #007acc;
    color: #ffffff;
    border: none;
}

QPushButton:hover {
    background-color: #0098ff;
}

QPushButton:pressed {
    background-color: #005c99;
}
